# ── BAC Anchor 部署配置 ───────────────────────────────────────
# 复制为 .env 后填写实际值；不要把真实 .env 提交到仓库。

# ── 镜像版本 ─────────────────────────────────────────────────
BAC_ANCHOR_RELEASE_VERSION=1.2.2

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=bac_anchor
POSTGRES_PASSWORD=
POSTGRES_DB=bac_anchor
PGDATA=/var/lib/postgresql/data

# ── Redis ────────────────────────────────────────────────────
REDIS_DB=0

# ── Anchor Server ────────────────────────────────────────────
BAC_ANCHOR_ENV=production
BAC_ANCHOR_PRIVATE_KEY_B64=
BAC_ANCHOR_KEY_ID=
BAC_ANCHOR_API_TOKEN=
BAC_ANCHOR_ADMIN_TOKEN=
BAC_ANCHOR_ENABLE_LEDGER_QUERY=false
BAC_ANCHOR_MAX_BODY_BYTES=8192
BAC_ANCHOR_RATE_LIMIT_PER_MINUTE=120
TZ=Asia/Shanghai
